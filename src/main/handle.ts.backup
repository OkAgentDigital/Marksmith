import {
  ipcMain,
  dialog,
  OpenDialogOptions,
  SaveDialogOptions,
  app,
  nativeImage,
  clipboard,
  BrowserWindow,
  shell,
  WebContentsView,
  powerMonitor,
  nativeTheme
} from 'electron'
import { existsSync, mkdirSync, writeFileSync } from 'fs'
import { writeFile } from 'fs/promises'
import { join } from 'path'

ipcMain.handle('showOpenDialog', async (_, options: OpenDialogOptions) => {
  return dialog.showOpenDialog(options)
})

ipcMain.handle('showSaveDialog', async (_, options: SaveDialogOptions) => {
  return dialog.showSaveDialog(options)
})

ipcMain.handle('getAssetsPath', async () => {
  const assetsPath = join(app.getPath('userData'), 'assets')
  if (!existsSync(assetsPath)) {
    mkdirSync(assetsPath, { recursive: true })
  }
  return assetsPath
})
ipcMain.handle('getFilePath', async (_, name: string) => {
  return join(app.getPath('userData'), 'assets', name)
})

ipcMain.handle('userDataPath', async () => {
  return app.getPath('userData')
})

async function initializeVaults() {
  const userDataPath = app.getPath('userData')
  const vaults = [
    { path: join(userDataPath, 'vault'), name: 'MD Vault' },
    { path: join(userDataPath, 'code-vault'), name: 'CODE Vault' }
  ]
  
  for (const vault of vaults) {
    if (!existsSync(vault.path)) {
      mkdirSync(vault.path, { recursive: true })
      
      // Create special workspace folders
      const workspaces = ['@toybox', '@inbox', '@sandbox', '@public', '@private', '@outbox']
      for (const workspace of workspaces) {
        const workspacePath = join(vault.path, workspace)
        mkdirSync(workspacePath, { recursive: true })
        
        // Create README.md for each workspace
        let readmeContent = `# ${workspace}\n\n`
        
        switch (workspace) {
          case '@toybox':
            readmeContent += `> Experimental scratch space. Nothing here is permanent.\n\nUse this folder for:\n- Drafting ideas\n- Testing syntax\n- Quick temporary notes\n\nFiles here are indexed and searchable.`
            break
          case '@inbox':
            readmeContent += `> Uncategorized incoming notes. Process regularly.\n\nNew notes created with \`Cmd+N\` go here by default.\n\n**Recommended workflow:**\n1. Review daily\n2. Add tags or frontmatter\n3. Move to appropriate folder\n4. Delete what's not needed`
            break
          case '@sandbox':
            readmeContent += `> Isolated testing area. Cross-vault links blocked by default.\n\nSafe for:\n- Testing destructive edits\n- Trying embeds and queries\n- Experimental formatting\n\n**Note:** Content here is excluded from search and export by default.`
            break
          case '@public':
            readmeContent += `> Notes ready for sharing or publishing.\n\nWhen you publish, this folder is the default source.\n\n**Requirements for publication:**\n- Complete frontmatter (title, date, tags)\n- No broken links\n- Reviewed for sensitive content`
            break
          case '@private':
            readmeContent += `> 🔒 Personal notes. Excluded from exports.\n\nUse for:\n- Daily journal\n- Personal reflections\n- Sensitive information\n\n**Note:** These are still plain markdown files. Encrypt at rest if needed.`
            break
          case '@outbox':
            readmeContent += `> Pending export or publishing queue.\n\nMove notes here when they're ready to be:\n- Published to a blog\n- Exported to PDF/HTML\n- Processed by external tools\n\nWhen publishing completes, files are moved to @public or deleted.`
            break
        }
        
        writeFileSync(join(workspacePath, 'README.md'), readmeContent)
      }
      
      // Create assets and templates directories
      mkdirSync(join(vault.path, 'assets'), { recursive: true })
      mkdirSync(join(vault.path, 'templates'), { recursive: true })
      
      // Create .gitkeep files
      writeFileSync(join(vault.path, 'assets', '.gitkeep'), '')
      
      // Create basic templates
      const dailyTemplate = `---
title: 
tags: []
date: ${new Date().toISOString().split('T')[0]}
---

# Daily Notes

## Tasks
- [ ] 

## Notes

## Ideas
`
      writeFileSync(join(vault.path, 'templates', 'daily.md'), dailyTemplate)
      
      const contactTemplate = `---
title: 
type: contact
name: 
email: 
phone: 
company: 
---

# Contact Notes

## About

## Meetings

## Follow Up
`
      writeFileSync(join(vault.path, 'templates', 'contact.md'), contactTemplate)
      
      const projectTemplate = `---
title: 
tags: [project]
status: planning
priority: medium
date: ${new Date().toISOString().split('T')[0]}
---

# Project: 

## Goals

## Tasks
- [ ] 

## Notes

## Resources
`
      writeFileSync(join(vault.path, 'templates', 'project.md'), projectTemplate)
      
      // Create vault README
      const vaultReadme = `# ${vault.name}

This is your ${vault.name} in Marksmith.

## Structure

- **@toybox/** - Experimental scratch space
- **@inbox/** - Uncategorized incoming notes
- **@sandbox/** - Isolated testing area
- **@public/** - Notes ready for sharing
- **@private/** - Personal/restricted notes
- **@outbox/** - Pending export/publish
- **assets/** - Images and attachments
- **templates/** - Note templates

## Getting Started

1. Use Cmd+N to create new notes (goes to @inbox by default)
2. Organize notes by moving them to appropriate folders
3. Use templates from the **templates/** folder
4. Attachments go in **assets/**

## Tips

- Use [[note]] syntax for internal linking
- Use #binder/note for binder references
- Tags help with organization and search
`
      writeFileSync(join(vault.path, 'README.md'), vaultReadme)
      
      // Create WELCOME.md
      const welcomeContent = `# Welcome to Marksmith! 🎉

## Quick Start

### 1. Create Your First Note
- Press Cmd+N to create a new note
- It will appear in the **@inbox** folder
- Give it a title and start writing

### 2. Organize Your Notes
- Drag notes between folders
- Use **@toybox** for experiments
- Use **@public** for polished content
- Use **@private** for personal notes

### 3. Use Templates
- Check the **templates/** folder
- Copy templates to create structured notes
- Create your own templates

### 4. Add Binders
- Go to Settings → Binders
- Add external folders as binders
- Access them with #binder/note syntax

### 5. Search & Navigate
- Use Cmd+P for quick search
- Use [[note]] for internal links
- Use #tag for tag search

## Workspace Folders

| Folder | Purpose |
|--------|---------|
| **@toybox** | Experiments and drafts |
| **@inbox** | New notes (default) |
| **@sandbox** | Safe testing area |
| **@public** | Ready to share |
| **@private** | Personal notes |
| **@outbox** | Export queue |

## Next Steps

- [ ] Explore the templates
- [ ] Set up your first binder
- [ ] Customize your workspace
- [ ] Review keyboard shortcuts

Happy writing! 📝`
      writeFileSync(join(vault.path, 'WELCOME.md'), welcomeContent)
    }
  }
  
  return { success: true, vaults }
}

export { initializeVaults }
ipcMain.handle('initializeVaults', initializeVaults)
ipcMain.handle('writeImageToClipboard', async (_, image: string) => {
  try {
    if (image.startsWith('data:image')) {
      // base64图片
      const base64Data = image.replace(/^data:image\/\w+;base64,/, '')
      const imageBuffer = Buffer.from(base64Data, 'base64')
      const object = nativeImage.createFromBuffer(imageBuffer)
      clipboard.writeImage(object)
    } else {
      // 文件路径
      const object = nativeImage.createFromPath(image)
      clipboard.writeImage(object)
    }
    return true
  } catch (e) {
    console.error('write image to clipboard error:', e)
    return false
  }
})

ipcMain.handle('downloadImage', async (_, url: string, name: string) => {
  try {
    const response = await fetch(url)
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`)
    }

    const contentLength = response.headers.get('content-length')
    if (contentLength && parseInt(contentLength) > 100 * 1024 * 1024) {
      return { exceed: true }
    }

    const buffer = await response.arrayBuffer()
    const filePath = join(app.getPath('userData'), 'assets', name)
    await writeFile(filePath, Buffer.from(buffer))
    return { name, exceed: false }
  } catch (e) {
    console.error('download image error:', e)
    return null
  }
})

ipcMain.on('print-pdf', async (e, data: { docId?: string; chatId?: string }) => {
  const win = BrowserWindow.fromWebContents(e.sender)
  if (win) {
    const view = new WebContentsView({
      webPreferences: {
        webviewTag: true,
        preload: join(__dirname, '../preload/index.js'),
        sandbox: false
      }
    })
    await view.webContents.loadFile(join(__dirname, '../renderer/worker.html'))
    // view.webContents.openDevTools()
    win.contentView.addChildView(view)
    view.setBounds({ x: 0, y: 0, width: 0, height: 0 })
    ipcMain.handleOnce('get-print-data', () => {
      return data
    })
    const ready = async () => {
      try {
        const save = await dialog.showSaveDialog({
          filters: [{ name: 'pdf', extensions: ['pdf'] }]
        })
        if (save.filePath) {
          const buffer = await view.webContents.printToPDF({
            printBackground: true,
            displayHeaderFooter: true,
            pageSize: 'A4',
            margins: {
              marginType: 'custom',
              bottom: 0,
              left: 0,
              top: 0,
              right: 0
            }
          })
          writeFileSync(save.filePath, buffer as any)
          shell.showItemInFolder(save.filePath)
        }
      } finally {
        win.contentView.removeChildView(view)
      }
    }
    ipcMain.once('print-pdf-ready', ready)
  }
})

ipcMain.on('showInFinder', (_, path: string) => {
  if (existsSync(path)) {
    shell.showItemInFolder(path)
  }
})

ipcMain.on('move-to-trash', (_, path: string) => {
  if (existsSync(path)) {
    shell.trashItem(path)
  }
})

powerMonitor.on('resume', () => {
  BrowserWindow.getAllWindows().forEach((win) => {
    win.webContents?.send('awake')
  })
})

nativeTheme.on('updated', () => {
  BrowserWindow.getAllWindows().forEach((win) => {
    win.webContents?.send('system-theme-changed')
  })
})
